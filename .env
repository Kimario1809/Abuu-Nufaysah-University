# Application Environment
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/abuu-nufaysah-university

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=abuu_university
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Session Configuration
SESSION_LIFETIME=3600
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# Security
CSRF_TOKEN_LENGTH=32
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_DECAY_MINUTES=15

# Email Configuration (for notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@abuu.edu
MAIL_FROM_NAME="Abuu Nufay'sah University"

# File Upload Configuration
UPLOAD_MAX_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Backup Configuration
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# Logging
LOG_LEVEL=error
LOG_PATH=./logs

# Push Notifications (Web Push)
VAPID_PUBLIC_KEY=BE5_o5hg63j-Wwv6YFnVSYLejxBnCzb6IwmX4H1qrobdCn9G-5p2VdXrRTD1eKVAFRmfRFUAqVYpeBkwf9iU_mc
